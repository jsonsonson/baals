<Module>
    <ModulePrefs title="classroom" />
    <Content type="html">
        <![CDATA[
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <!-- Força o navegador a ignorar a URL esquisita do Module e usar o seu GitHub como raiz para tudo -->
    <base href="https://cdn.jsdelivr.net/gh/jsonsonson/baals@main/">
    
    <script>
    // FIX ABSOLUTO PARA MODULE: Sobrescreve a localização do documento para a engine não se perder
    const REPO_URL = "https://cdn.jsdelivr.net/gh/jsonsonson/baals@main/";
    
    // Força o empacotador de pacotes (bundles) a olhar pro lugar certo
    window.GAME_CONFIG = {
        pokiSdkDebug: false,
        leaderboard: 'mockup',
        bundlesPath: REPO_URL + 'bundles',
    };
    window.NOSW = true;

    // Bloqueia tentativas da engine de ler a URL do iframe do Module
    Object.defineProperty(window, 'location', {
        value: {
            href: REPO_URL,
            protocol: 'https:',
            host: 'cdn.jsdelivr.net',
            pathname: '/gh/jsonsonson/baals@main/',
            search: '',
            hash: ''
        },
        writable: false
    });

    // Burlar o bloqueio de CORS do Web Worker dentro do Module
    const OriginalWorker = window.Worker;
    window.Worker = function(scriptURL) {
        let fullURL = scriptURL;
        if (!fullURL.startsWith('http')) {
            fullURL = REPO_URL + fullURL.replace(/^\//, '');
        }
        // Se o seu repositório usa .webp.json ou nomes assim, o worker precisa achar direto
        const blobCode = "importScripts('" + fullURL + "');";
        const blob = new Blob([blobCode], { type: 'application/javascript' });
        const blobURL = URL.createObjectURL(blob);
        return new OriginalWorker(blobURL);
    };
    </script>

    <script src="poki-sdk.js"></script>
    <meta http-equiv="content-type" content="text/html; charset=UTF8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="height=device-height, initial-scale=1.0, minimum-scale=1.0, maximum-scale=1.0, user-scalable=no, minimal-ui, viewport-fit=cover"/>

    <title>Subway Surfers</title>
    <style>
        body, html {
            margin: 0; height: 100%; background-color: #0b316b; overflow: hidden;
            background-image: url('assets/preload/splash.webp'); background-repeat: no-repeat; background-position: center;
        }
        #message { text-align: center; font-size: 8px; z-index: 5; font-family: "Verdana", sans-serif; color: #fff; position: fixed; width: 100%; z-index: 9999; }
        .dot { display: inline; margin-left: 0.2em; margin-right: 0.2em; position: relative; top: -1em; font-size: 3.5em; opacity: 0; animation: showHideDot 2.5s ease-in-out infinite; }
        .dot.one { animation-delay: 0.2s; } .dot.two { animation-delay: 0.4s; } .dot.three { animation-delay: 0.6s; }
        @keyframes showHideDot { 0% { opacity: 0; } 50% { opacity: 1; } 60% { opacity: 1; } 100% { opacity: 0; } }
    </style>
</head>
<body>

<div id="message" style="display:none;">
    <h1>Loading</h1>
    <h1 class="dot one">.</h1>
    <h1 class="dot two">.</h1>
    <h1 class="dot three">.</h1>
</div>

<script>
    // Injeção de save nas localStorage
    localStorage.setItem('subway-surfers-v_profile', JSON.stringify({
      "name": "Kamegame unlockedAll", "muted": false, "tutorial": false, "adConsent": false,
      "wordHunt": { "word": "wO=w*/DGOr@8", "currentLetter": "", "completed": [] },
      "currencies": { "coins": 9999999, "keys": 9999999 }, "highscore": 9999999,
      "missions": [[{"id": "mission-score-onerun", "progress": 9999999}]], "rewardedBreakPrize": 0
    }));

    localStorage.setItem('ShopSettings', JSON.stringify({
      "selectedCharacter": "ninja",
      "purchased": {
        "characters": ["jake", "tricky", "fresh", "spike", "yutani", "king", "lucy", "ninja", "tagbot", "tasha", "brody"],
        "outfits": [],
        "boards": ["hoverboard", "bigkahuna", "bouncer", "daredevil", "greatwhite", "hotrod", "lowrider", "lumberjack", "monster", "scoot", "skullfire", "starboard", "sunset", "superhero", "teleporter", "windglider"],
        "boosts": {
          "consumables": { "hoverboard": 999999, "mysteryBox": 999, "scoreBooster": 999999, "headstart": 999999 },
          "permanents": { "jetpack": 6, "sneakers": 6, "magnet": 6, "multiplier": 6 }
        }
      }
    }));

    function iniciarJogo(idioma) {
      console.log("Iniciando jogo no modo Gadget Module para:", idioma);
      
      const originalFetch = window.fetch;
      window.fetch = async function(...args) {
        let url = args[0];
        
        if (typeof url === 'string') {
          url = decodeURIComponent(url);

          if (url.includes('?')) {
            url = url.split('?')[0];
          }

          // Se a URL for um blob ou base64 estranho gerado pelo module, deixa passar direto
          if (url.startsWith('data:') || url.startsWith('blob:')) {
             return originalFetch.apply(this, args);
          }

          // Converte qualquer rota relativa ou lixo de IP para o caminho absoluto do GitHub
          if (!url.startsWith('http://') && !url.startsWith('https://')) {
             url = REPO_URL + url.replace(/^\//, '');
          } else if (url.startsWith('http://192.168')) {
             const limpaLocal = url.replace(/^http:\/\/192\.168\.[0-9.]+(:[0-9]+)?\//, '');
             url = REPO_URL + limpaLocal.replace(/^\//, '');
          }

          args[0] = url;
        }
        return originalFetch.apply(this, args);
      };

      // Desbloqueador automático de som ao interagir
      const liberarAudio = () => {
          if (window.audioContext && window.audioContext.state === 'suspended') {
              window.audioContext.resume();
          }
          window.removeEventListener('click', liberarAudio);
          window.removeEventListener('touchstart', liberarAudio);
      };
      window.addEventListener('click', liberarAudio);
      window.addEventListener('touchstart', liberarAudio);

      document.getElementById('message').style.display = 'block';

      const scriptLoading = document.createElement('script');
      scriptLoading.src = REPO_URL + "js/loading.js";
      document.body.appendChild(scriptLoading);

      const scriptBoot = document.createElement('script');
      scriptBoot.src = REPO_URL + "js/boot.js";
      document.body.appendChild(scriptBoot);
    }

    const listaIdiomas = navigator.languages && navigator.languages.length > 0 ? navigator.languages : [navigator.language || ''];
    const idiomaPrincipal = listaIdiomas[0].toLowerCase();

    if (idiomaPrincipal.startsWith('pt')) {
      iniciarJogo('pt');
    } else {
      iniciarJogo('en');
    }
</script>
</body>
</html>

        ]]>
    </Content>
</Module>
